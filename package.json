{
	"name": "dblocks-codepro",
	"version": "1.4.3",
	"description": "Example block scaffolded with Create Block tool.",
	"author": "The WordPress Contributors",
	"license": "GPL-2.0-or-later",
	"main": "build/index.js",
	"scripts": {
		"build": "wp-scripts build --blocks-manifest",
		"build:admin": "wp-scripts build src/admin/index.js --output-path=build/admin",
		"build:footer-editor": "wp-scripts build src/footer-editor/index.js --output-path=build/footer-editor",
		"build:all": "npm run build && npm run build:admin && npm run build:footer-editor",
		"start": "wp-scripts start --blocks-manifest",
		"format": "wp-scripts format",
		"lint:css": "wp-scripts lint-style",
		"lint:js": "wp-scripts lint-js",
		"packages-update": "wp-scripts packages-update",
		"plugin-zip": "wp-scripts plugin-zip"
	},
	"files": [
		"*"
	],
	"devDependencies": {
		"@wordpress/scripts": "^30.24.0"
	},
	"dependencies": {
		"@wordpress/icons": "^10.31.0",
		"emmet-monaco-es": "^5.6.1",
		"monaco-editor": "^0.55.1"
	}
}
